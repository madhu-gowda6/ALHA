# AWS Configuration
AWS_REGION=us-east-1

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# ALB / API Gateway
ALB_DNS=alha-alb-xxxxxxxxxxxx.us-east-1.elb.amazonaws.com
API_GW_URL=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com

# S3 Buckets
S3_IMAGE_BUCKET=alha-images
S3_FRONTEND_BUCKET=alha-frontend

# Claude Agent SDK / Bedrock
CLAUDE_CODE_USE_BEDROCK=1
ANTHROPIC_CUSTOM_HEADERS=X-Amzn-Bedrock-GuardrailIdentifier:<id>\nX-Amzn-Bedrock-GuardrailVersion:1

# DynamoDB Tables
CONSULTATIONS_TABLE=alha-consultations
VETS_TABLE=alha-vets
FARMERS_TABLE=alha-farmers
DISEASE_MODELS_TABLE=alha-disease-models

# Rekognition Custom Labels
REKOGNITION_CATTLE_ARN=arn:aws:rekognition:us-east-1:123456789012:project/cattle-model/version/v1/XXXX
REKOGNITION_POULTRY_ARN=arn:aws:rekognition:us-east-1:123456789012:project/poultry-model/version/v1/XXXX

# Bedrock Knowledge Base
BEDROCK_KB_ID=XXXXXXXXXX
